# Copy to /opt/avnzor/config/application.env on the server.
# Never commit real secrets. Set values on the server or inject via your deployment pipeline.

SPRING_PROFILES_ACTIVE=prod

SERVER_PORT=8080

DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

JWT_SECRET=
JWT_EXPIRATION=86400000

LOG_FILE_PATH=/opt/avnzor/logs/application.log

# Optional integrations (add as needed per environment)
TRACKING_API_URL=
SHIPPING_PROVIDER_URL=
SHIPPING_PROVIDER_API_KEY=
NOTIFICATION_WEBHOOK_URL=
